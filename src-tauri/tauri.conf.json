{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Messenger",
  "version": "0.1.0",
  "identifier": "io.github.whitersun.unofficial-messenger",
  "build": {
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": " Messenger",
        "url": "https://www.messenger.com/",
        "width": 1200,
        "height": 800,
        "minWidth": 420,
        "minHeight": 520,
        "resizable": true,
        "create": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'none'; form-action 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
